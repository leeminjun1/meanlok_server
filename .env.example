# 필수 (값을 채워야 실행 가능)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
GROQ_API_KEY=""

# 선택 (기본값 있음, 재정의 시만 설정)
PORT=3001
CORS_ORIGIN="http://localhost:3000"
SUPABASE_STORAGE_BUCKET="meanlok-images"
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
AI_MAX_RESPONSE_TOKENS=512
AI_QUESTION_CACHE_TTL_SEC=30
AI_ESTIMATED_TOKENS_PER_REQUEST=700
AI_DAILY_TOKEN_BUDGET=20000
UPLOAD_MAX_IMAGE_BYTES=5242880
AI_RATE_LIMIT_WINDOW_SEC=60
AI_RATE_LIMIT_MAX_REQUESTS=10
AI_REDIS_REST_URL=""
AI_REDIS_REST_TOKEN=""
